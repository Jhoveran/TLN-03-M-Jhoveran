interface Loopback0
 ip address 200.0.0.1 255.255.255.255
!
interface Ethernet0/1
 ip address 10.0.0.2 255.255.255.252
 no shut
!
interface Ethernet0/2
 ip address 172.16.0.1 255.255.255.252
 no shut
!
interface Ethernet0/3
 ip address 10.0.0.69 255.255.255.252
 no shut
!
router ospf 1
 router-id 20.1.1.3
 network 172.16.0.0 0.0.0.3 area 0
 network 10.0.0.68 0.0.0.3 area 0
 network 200.0.0.1 0.0.0.0 area 0
 default-information originate always
!
ip forward-protocol nd
!
ip http server
ip http secure-server
ip route 0.0.0.0 0.0.0.0 10.0.0.1
!
ip as-path access-list 1 permit ^$
!
router bgp 400 
 network 192.168.10.0 mask 255.255.255.0
 network 192.168.20.0 mask 255.255.255.0 
 neighbor 10.0.0.1 remote-as 100
 neighbor 10.0.0.1 filter-list 1 out
 neighbor 200.0.0.2 remote-as 400
 neighbor 200.0.0.2 update-source Loopback0
 neighbor 200.0.0.2 next-hop-self
!
